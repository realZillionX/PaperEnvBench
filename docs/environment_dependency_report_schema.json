{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "PaperEnvBench attempt environment dependency report",
  "type": "object",
  "required": [
    "runtime",
    "python_packages",
    "dependency_profiles",
    "route_boundary",
    "dependency_inventory",
    "heavyweight_dependency_decisions",
    "verification",
    "validation_experiments"
  ],
  "properties": {
    "runtime": {
      "type": "object",
      "description": "Observed runtime evidence such as python, platform, nvidia-smi, torch.cuda, CUDA wheel tags, GPU memory and system build tools."
    },
    "dependency_profiles": {
      "type": "array",
      "description": "Environment dependency slices relevant to the task. For L4, every profile in the task's bound profile closure must be present with status=pass.",
      "items": {
        "type": "object",
        "required": [
          "profile_id",
          "status"
        ],
        "properties": {
          "profile_id": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "blocked",
              "partial",
              "not_applicable"
            ]
          },
          "evidence": {
            "type": [
              "object",
              "array",
              "string"
            ]
          },
          "blockers": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        },
        "additionalProperties": true
      }
    },
    "python_packages": {
      "type": [
        "array",
        "object"
      ],
      "description": "Installed package evidence such as torch, torchvision, torchaudio, framework packages and task-specific dependency pins."
    },
    "system_packages": {
      "type": [
        "array",
        "object"
      ],
      "description": "System package and binary probes such as ffmpeg, libsndfile, libGL, gcc, g++, cmake, ninja, nvcc and pkg-config."
    },
    "native_extensions": {
      "type": [
        "array",
        "object",
        "null"
      ],
      "description": "Native C++ / CUDA extension build or import evidence."
    },
    "checkpoints_and_assets": {
      "type": [
        "array",
        "object",
        "null"
      ],
      "description": "Checkpoint, dataset, asset, cache, license and checksum boundary evidence."
    },
    "route_boundary": {
      "type": "object",
      "description": "Full repository route and any reduced route used for the attempt.",
      "required": [
        "full_repository_route",
        "attempt_route"
      ],
      "properties": {
        "full_repository_route": {
          "type": [
            "array",
            "string"
          ]
        },
        "attempt_route": {
          "type": [
            "array",
            "string"
          ]
        },
        "reduced_route_reason": {
          "type": [
            "string",
            "null"
          ]
        },
        "checkpoint_boundary": {
          "type": [
            "object",
            "array",
            "string",
            "null"
          ]
        },
        "native_extension_boundary": {
          "type": [
            "object",
            "array",
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "dependency_inventory": {
      "type": [
        "array",
        "object"
      ],
      "description": "Complete task dependency inventory discovered from repository files and documentation. Include Python packages, system packages, CUDA or accelerator stack, native extensions, checkpoints, datasets, simulator/rendering dependencies, cache paths and license/API gates even when the final bounded route cannot install or execute all of them.",
      "items": {
        "type": "object",
        "required": [
          "name",
          "kind",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "kind": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "installed",
              "probed",
              "blocked",
              "deferred_with_evidence",
              "not_required_by_visible_route",
              "not_applicable"
            ]
          },
          "evidence": {
            "type": [
              "object",
              "array",
              "string"
            ]
          },
          "blocker": {
            "type": [
              "object",
              "array",
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "heavyweight_dependency_decisions": {
      "type": [
        "array",
        "object"
      ],
      "description": "Decision log for large, slow, gated or hardware-sensitive dependencies. Do not omit multi-GB checkpoints, datasets, CUDA/native builds or simulator stacks merely because the bounded validation route is smaller. Blocked, partial, not_applicable, or deferred decisions may explain lower levels, but L4 requires the full minimal reproduction dependency route to be installed or probed.",
      "items": {
        "type": "object",
        "required": [
          "name",
          "decision",
          "evidence"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "decision": {
            "type": "string",
            "enum": [
              "installed",
              "probed",
              "blocked",
              "deferred_with_evidence",
              "not_required_by_visible_route"
            ]
          },
          "evidence": {
            "type": [
              "object",
              "array",
              "string"
            ]
          },
          "reason": {
            "type": [
              "string",
              "null"
            ]
          }
        },
        "additionalProperties": true
      }
    },
    "verification": {
      "type": "object",
      "description": "Commands or probe results proving the runtime and route evidence.",
      "properties": {
        "commands": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "probe_results": {
          "type": [
            "array",
            "object"
          ]
        }
      },
      "additionalProperties": true
    },
    "validation_experiments": {
      "type": [
        "array",
        "object"
      ],
      "description": "Small but representative paper-key experiment checks, including command, status, output artifacts and metrics. L4 requires at least one passed task minimal reproduction, verifier, single-sample inference, render, rollout, sample, or metric smoke.",
      "items": {
        "type": "object",
        "required": [
          "name",
          "command",
          "status"
        ],
        "properties": {
          "name": {
            "type": "string"
          },
          "command": {
            "type": "string"
          },
          "status": {
            "type": "string",
            "enum": [
              "pass",
              "blocked",
              "partial",
              "failed"
            ]
          },
          "metrics": {
            "type": [
              "object",
              "array"
            ]
          },
          "artifacts": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
